<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:fillViewport="true"
    android:layout_height="match_parent"
    xmlns:ads="http://schemas.android.com/apk/res-auto">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

  <android.support.v7.widget.Toolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/colorPrimary"
      android:fitsSystemWindows="true"
      android:theme="@style/ThemeOverlay.AppCompat.Dark" />

  <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

  <android.support.v7.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:orientation="horizontal"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <LinearLayout
          android:layout_marginTop="10dp"
          android:layout_width="match_parent"
          android:gravity="center"
          android:layout_height="wrap_content">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_sms" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:gravity="center"
            android:textAllCaps="true"
            android:fontFamily="@font/helvetica_bold"
            android:text="@string/send_sms"
            android:textColor="@color/colorPrimary"
            android:textSize="16sp"/>
      </LinearLayout>

      <View
          android:id="@+id/divider"
          android:layout_width="170dp"
          android:layout_gravity="center"
          android:layout_height="1dp"
          android:alpha="0.3"
          android:background="@color/fiord" />

      <TextView
        android:id="@+id/text_view_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp"
        android:gravity="start"
          android:fontFamily="@font/helvetica_roman"
        android:text="@string/hello"
        android:textColor="@color/fiord"
        android:textSize="13sp"/>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <android.support.v7.widget.CardView
          android:id="@+id/wrapper_message"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          app:cardCornerRadius="20dp"
          app:cardElevation="2dp"
          app:cardUseCompatPadding="true">
          <ImageView
              android:scaleType="fitXY"
              android:src="@drawable/bank_border_2"
              android:layout_width="match_parent"
              android:layout_height="match_parent"/>

          <EditText
            android:id="@+id/edit_text_message"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_margin="5dp"
            android:layout_gravity="center"
            android:padding="10dp"
              android:background="@null"
              tools:text="Some text"
            android:gravity="start"
              android:textSize="13sp"
            android:hint="@string/hello"
              android:textColorHint="@color/colorPrimary"
            android:inputType="textMultiLine"
              android:fontFamily="@font/helvetica_bold"
            android:textColor="@color/colorPrimary"
            tools:ignore="Autofill"/>
        </android.support.v7.widget.CardView>
      </LinearLayout>
    </LinearLayout>
  </android.support.v7.widget.CardView>


      <ImageView
          app:srcCompat="@drawable/ic_ellipse"
          android:scaleType="fitXY"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"/>
  </FrameLayout>

  <FrameLayout
      android:layout_weight="1"
      android:layout_width="match_parent"
      android:layout_height="0dp">
  <Button
      android:id="@+id/button_send"
      style="@style/ClickableWrapper"
      android:layout_width="195dp"
      android:layout_height="45dp"
      android:layout_gravity="center"
      android:background="@drawable/toggle_button_sip_background"
      android:text="@string/send"
      android:textAllCaps="true"
      android:textColor="@color/white" />
  </FrameLayout>
  <com.google.android.gms.ads.AdView
      android:id="@+id/ad_view"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="10dp"
      ads:adSize="MEDIUM_RECTANGLE"
      ads:adUnitId="@string/add_unit_id"/>
</LinearLayout>
</ScrollView>