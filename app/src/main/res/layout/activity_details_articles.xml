<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/text_title_details_article"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="46dp"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="121dp"
        android:text="Title Details Articles"
        app:layout_constraintBottom_toTopOf="@+id/recyclerView_Info"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_content_details_article"
        android:layout_width="285dp"
        android:layout_height="92dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="1dp"
        android:text="Content Details Article"
        app:layout_constraintBottom_toTopOf="@+id/recyclerView_Info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.425"
        app:layout_constraintStart_toStartOf="@+id/text_title_details_article"
        app:layout_constraintTop_toBottomOf="@+id/text_title_details_article" />

    <android.support.v7.widget.RecyclerView
        android:id="@+id/recyclerView_Info"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="27dp"
        android:layout_marginEnd="27dp"
        android:layout_marginBottom="91dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_title_details_article" />

</android.support.constraint.ConstraintLayout>