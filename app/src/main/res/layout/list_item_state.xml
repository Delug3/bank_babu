<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_container"
    style="@style/ClickableWrapper"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:elevation="13dp"
    android:background="@drawable/bank_border">

    <TextView
        android:id="@+id/text_view_title"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_margin="20dp"
        android:ellipsize="end"
        android:fontFamily="@font/helvetica_bold"
        android:gravity="start|center"
        android:textAllCaps="true"
        android:textColor="@color/fiord"
        android:textSize="14sp"
        android:textStyle="normal"
        tools:text="@string/hello"/>

    <ImageView
        android:id="@+id/image_view_bookmark"
        android:layout_width="@dimen/heart_size"
        android:layout_height="@dimen/heart_size"
        android:layout_gravity="center|end"
        android:layout_margin="12dp"
        android:background="?selectableItemBackgroundBorderless"
        android:padding="10dp"
        app:srcCompat="@drawable/ic_heart_off"
        tools:ignore="ContentDescription"/>

</android.support.v7.widget.CardView>