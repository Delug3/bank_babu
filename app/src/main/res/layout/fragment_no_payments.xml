<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whisper"
    tools:context=".fragments.NoPaymentsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ic_bank_balance_bg"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/contacts_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?selectableItemBackground">

            <ImageView
                android:id="@+id/image_contacts"
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_gravity="center"
                android:src="@drawable/payments_contacts" />
        </FrameLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="220dp"
            android:layout_height="1dp"
            android:alpha="0.3"
            android:background="@color/fiord" />

        <FrameLayout
            android:id="@+id/account_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?selectableItemBackground">

            <ImageView
                android:id="@+id/image_account"
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_gravity="center"
                android:src="@drawable/payment_accounts" />
        </FrameLayout>

    </LinearLayout>
</FrameLayout>